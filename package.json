{
  "name": "makrowisp",
  "private": true,
  "author": {
    "name": "Martin Sanchez",
    "url": "https://keysoft.com.mx"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "dev:api": "turbo run dev --filter=api",
    "dev:payment": "turbo run dev --filter=payment-gateway",
    "dev:admin": "turbo run dev --filter=admin",
    "build:api": "turbo run build --filter=api"
  },
  "devDependencies": {
    "turbo": "^2.9.18"
  }
}